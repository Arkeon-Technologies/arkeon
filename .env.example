# =====================================================================
# REQUIRED — the API (and docker compose) will refuse to start without
# these. Copy this file to `.env` and fill in real values.
# =====================================================================

# Admin bootstrap key. On first boot, an admin API key is seeded from this
# value. Rotate after first use.
# Generate: echo "ak_$(openssl rand -hex 32)"
ADMIN_BOOTSTRAP_KEY=

# Symmetric encryption key for secrets at rest (AES-256-GCM).
# MUST be exactly 64 hex chars (32 bytes). Losing this bricks encrypted data.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Meilisearch master key. Any random string >= 16 bytes.
# Generate: openssl rand -hex 24
MEILI_MASTER_KEY=

# Postgres superuser password (used by the local compose postgres service
# and by the migrate service). For local dev only — do not expose the
# Postgres port publicly.
#
# IMPORTANT: This value is embedded verbatim into the migrate service's
# DATABASE_URL. Use URL-safe characters only (alphanumeric recommended).
# Passwords containing @ : / ? # $ will either break URL parsing or be
# re-interpolated by compose. If you need special characters, set
# MIGRATION_DATABASE_URL explicitly above with the password percent-encoded.
POSTGRES_PASSWORD=arke

# =====================================================================
# Database
# =====================================================================

# App-user connection string. Used by the API at runtime; subject to RLS.
DATABASE_URL=postgresql://arke_app:arke@localhost:5432/arke

# Superuser connection string. Used only by `npm run migrate` and by the
# `migrate` compose service to run DDL. Must be a role with CREATE privilege.
MIGRATION_DATABASE_URL=postgresql://arke:arke@localhost:5432/arke

# =====================================================================
# Ports (local docker compose)
# =====================================================================
PORT=8000
PG_PORT=5432
REDIS_PORT=6379
MEILI_PORT=7700

# =====================================================================
# Search
# =====================================================================
# In docker-compose, leave unset — it defaults to http://meilisearch:7700.
# When running the API on the host (npm run dev), point at the local port.
# MEILI_URL=http://localhost:7700

# =====================================================================
# Storage
# =====================================================================
STORAGE_BACKEND=local
# STORAGE_DIR=./data/files

# S3 / R2 / MinIO (only when STORAGE_BACKEND=s3)
# S3_ENDPOINT=
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# =====================================================================
# Knowledge extraction pipeline (opt-in, off by default)
# See docs/ADVANCED.md for setup and cost notes.
# =====================================================================
ENABLE_KNOWLEDGE_PIPELINE=false
# OPENAI_API_KEY=
# KNOWLEDGE_POLLER_INTERVAL_MS=10000
# MAX_KNOWLEDGE_CONCURRENCY=10
# CHUNK_EXTRACT_CONCURRENCY=4

# =====================================================================
# Worker runtime tuning (advanced)
# =====================================================================
# MAX_CONCURRENT_WORKERS=4
# MAX_QUEUE_DEPTH=50
# MAX_INVOCATION_DEPTH=5
# MAX_INVOCATION_RETRIES=3
# DRAIN_TIMEOUT_MS=320000

# =====================================================================
# Misc
# =====================================================================
# ARKE_API_URL=                  # internal SDK base URL (knowledge service)
# API_BASE_URL=                  # self-URL for worker invocations
# REDIS_URL=                     # enables BullMQ backend; falls back to in-process queue
# E2E_BASE_URL=http://localhost:8000
