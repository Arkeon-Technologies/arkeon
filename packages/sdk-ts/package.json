{
  "name": "@arkeon-technologies/sdk",
  "version": "0.1.3",
  "description": "Lightweight TypeScript SDK for the Arkeon API",
  "repository": {
    "type": "git",
    "url": "https://github.com/Arkeon-Technologies/arkeon",
    "directory": "packages/sdk-ts"
  },
  "keywords": [
    "arkeon",
    "sdk",
    "api",
    "knowledge-graph"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "undici": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "undici": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Arkeon Technologies, Inc.",
  "license": "Apache-2.0"
}
