{
  "name": "arkeon",
  "version": "0.1.0",
  "description": "Command-line interface for the Arkeon API",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arkeon-Technologies/arkeon.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "arkeon": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "fetch-spec": "tsx scripts/fetch-openapi.ts",
    "generate": "tsx scripts/generate-commands.ts",
    "bundle-assets": "tsx scripts/bundle-assets.ts",
    "build": "npm run fetch-spec && npm run generate && npm run bundle-assets && tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "conf": "^13.0.1"
  },
  "devDependencies": {
    "@arkeon-technologies/shared": "*",
    "@types/node": "^24.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Arkeon Technologies, Inc.",
  "license": "Apache-2.0"
}
