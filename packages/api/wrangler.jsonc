{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "arke-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-25",
  "observability": {
    "enabled": true
  },
  "vars": {
    "ROOT_COMMONS_ID": "00000000000000000000000000",
    "R2_BUCKET_NAME": "arke-api-files-prod"
  },
  "r2_buckets": [
    {
      "binding": "FILES_BUCKET",
      "bucket_name": "arke-api-files-prod"
    }
  ]
}
