# Dependencies (reproduced via `npm ci` inside the image)
node_modules
**/node_modules

# Build output (rebuilt inside the image)
dist
**/dist
build
**/build
.next
**/.next
*.tsbuildinfo
**/*.tsbuildinfo

# Git metadata
.git
.gitignore
.gitattributes

# CI / repo meta (not needed at runtime)
.github
.claude

# Editor / OS junk
.vscode
.idea
*.swp
.DS_Store
Thumbs.db

# Env files (secrets never belong in images; .env.example is unnecessary too)
.env
.env.*

# Local dev state
.devports
.worktrees
.claude/worktrees
tasks
data

# Logs and coverage
*.log
coverage
.nyc_output

# Docs and planning (not needed at runtime)
docs
README.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
CLA.md
NOTICE

# Python build artifacts
__pycache__
**/__pycache__
*.pyc
**/*.pyc
*.egg-info
**/*.egg-info
.pytest_cache
**/.pytest_cache

# Docker / compose (not needed inside the image)
Dockerfile
.dockerignore
docker-compose*.yml
